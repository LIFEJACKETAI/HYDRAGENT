generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("general") // restaurant, doctor, dentist, mechanic, etc.
  description String?
  address     String?
  phone       String?
  email       String?
  website     String?
  hours       String?  // JSON string for business hours
  logoUrl     String?
  primaryColor   String @default("#0d9488")
  accentColor    String @default("#f59e0b")
  widgetPosition String @default("bottom-right")
  widgetGreeting String @default("Hi! How can I help you today?")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeDoc {
  id        String   @id @default(cuid())
  title     String
  content   String   // text content of the document
  fileType  String   @default("text") // text, pdf, docx
  fileSize  Int      @default(0)
  source    String   @default("upload") // upload, paste, url
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          String   @id @default(cuid())
  customerName  String
  customerEmail String?
  customerPhone String?
  service      String
  date         DateTime
  duration     Int      @default(30) // minutes
  status       String   @default("scheduled") // scheduled, confirmed, cancelled, completed, no-show
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailRecord {
  id          String   @id @default(cuid())
  from        String
  to          String
  subject     String
  body        String
  direction   String   // inbound, outbound
  status      String   @default("sent") // sent, received, draft, failed
  appointmentId String?
  createdAt   DateTime @default(now())
}

model CallLog {
  id           String   @id @default(cuid())
  customerName  String?
  customerPhone String
  direction    String   // inbound, outbound
  duration     Int?     // seconds
  status       String   @default("completed") // completed, missed, voicemail, scheduled
  notes        String?
  recordingUrl String?
  createdAt    DateTime @default(now())
}

model SmsLog {
  id            String   @id @default(cuid())
  customerPhone String
  direction     String   // inbound, outbound
  body          String
  status        String   @default("sent")
  createdAt     DateTime @default(now())
}

model BookingLead {
  id            String   @id @default(cuid())
  customerPhone String
  customerName  String?
  lastService   String?
  lastContacted DateTime @default(now())
  isConverted   Boolean  @default(false)
}

model Integration {
  id          String   @id @default(cuid())
  type        String   // google_calendar, outlook_calendar, sendgrid, twilio, etc.
  name        String
  status      String   @default("disconnected") // connected, disconnected, error
  config      String?  // JSON string for integration config
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user, assistant, system
  content   String
  createdAt DateTime @default(now())
}